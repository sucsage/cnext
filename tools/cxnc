#!/usr/bin/env python3
"""
cxnc — CXN template compiler
แปลง .cxn → .c สำหรับ cnext framework

File-based routing (Next.js-style):
  src/page.cxn              → GET /
  src/blog/page.cxn         → GET /blog
  src/user/profile/page.cxn → GET /user/profile
  src/layout.cxn            → root layout, ครอบทุก page อัตโนมัติ

Syntax:
  <%inc db/db.h %>        → #include "db/db.h"
  <%inc <stdlib.h> %>     → #include <stdlib.h>
  @route /path            → override route ที่ derive จาก path (optional)
  @fn funcname            → public helper (no route, for shared partials)
  @meta key "value"       → per-page metadata (title, description, og_image, canonical)
  <% c_code; %>           → raw C code ใน render()
  <%! ... %>              → C code ที่ file scope (multi-line, ปิดด้วย %> บรรทัดเดียว)
  {{expr}}                → page_writef(ctx, "%s", expr);
  {{children}}            → (เฉพาะใน layout.cxn) จุดที่ page เนื้อในจะถูก render
  HTML อื่นๆ              → page_write(ctx, "...");
"""
import sys
import re
import os


def esc(s):
    """Escape string สำหรับ C double-quoted string literal"""
    s = s.replace('\\', '\\\\')
    s = s.replace('"', '\\"')
    return s


def derive_route(src_path):
    """
    src/page.cxn              → '/'
    src/blog/page.cxn         → '/blog'
    src/user/profile/page.cxn → '/user/profile'
    """
    p = src_path.replace(os.sep, '/')
    if p.startswith('src/'):
        p = p[4:]
    if p == 'page.cxn':
        return '/'
    if p.endswith('/page.cxn'):
        return '/' + p[:-len('/page.cxn')]
    return None


def process(src_path, dst_path):
    with open(src_path, encoding='utf-8') as f:
        lines = f.readlines()

    basename  = os.path.basename(src_path)
    is_layout = basename == 'layout.cxn'
    is_page   = basename == 'page.cxn'

    includes = []
    route = derive_route(src_path) if is_page else None
    fn_name = None
    meta = {}                        # @meta key → C string literal value (already escaped)
    scope_lines = []
    body_lines = []
    in_scope = False
    in_code = False                  # inside a multi-line <% ... %> block
    has_children_marker = False

    META_KEYS = ('title', 'description', 'og_image', 'canonical')

    for raw in lines:
        line = raw.rstrip('\n')

        # ── <%! multi-line file-scope block ──────────────────────────────
        if in_scope:
            if line.strip() == '%>':
                in_scope = False
            else:
                scope_lines.append(line)
            continue

        if re.match(r'^\s*<%!', line):
            in_scope = True
            rest = re.sub(r'^\s*<%!', '', line).strip()
            if rest:
                scope_lines.append(rest)
            continue

        # ── <%inc header %> ──────────────────────────────────────────────
        m = re.match(r'^\s*<%inc\s+(.+?)\s*%>\s*$', line)
        if m:
            val = m.group(1).strip()
            if val.startswith('<'):
                includes.append(f'#include {val}')
            else:
                includes.append(f'#include "{val}"')
            continue

        # ── @route /path (override path-derived route) ───────────────────
        m = re.match(r'^\s*@route\s+(\S+)', line)
        if m:
            route = m.group(1)
            continue

        # ── @fn funcname — public helper, no route ───────────────────────
        m = re.match(r'^\s*@fn\s+(\S+)', line)
        if m:
            fn_name = m.group(1)
            continue

        # ── @meta key "value" — per-page metadata ────────────────────────
        m = re.match(r'^\s*@meta\s+(\w+)\s+"(.*)"\s*$', line)
        if m:
            key, val = m.group(1), m.group(2)
            if key not in META_KEYS:
                print(f'[cxnc] warning: {src_path}: unknown @meta key "{key}" '
                      f'(known: {", ".join(META_KEYS)})', file=sys.stderr)
            else:
                meta[key] = esc(val)
            continue

        # ── <% ... %> multi-line C code (close with %> on its own line) ──
        if in_code:
            if line.strip() == '%>':
                in_code = False
            else:
                body_lines.append(('raw', line))
            continue

        # ── <% single-line C code %> ─────────────────────────────────────
        m = re.match(r'^\s*<%(.+?)%>\s*$', line)
        if m:
            body_lines.append(('raw', m.group(1).strip()))
            continue

        # ── <% opens a multi-line code block (no closing %> on this line) ─
        m = re.match(r'^\s*<%(.*)$', line)
        if m and '%>' not in line and not line.lstrip().startswith('<%!') \
                and not line.lstrip().startswith('<%inc'):
            in_code = True
            rest = m.group(1)
            if rest.strip():
                body_lines.append(('raw', rest))
            continue

        # ── บรรทัดที่มี {{expr}} หรือ {{children}} ───────────────────────
        if '{{' in line:
            parts = re.split(r'(\{\{.*?\}\})', line)
            has_content = False
            for part in parts:
                mm = re.match(r'^\{\{(.+?)\}\}$', part)
                if mm:
                    expr = mm.group(1).strip()
                    if is_layout and expr == 'children':
                        body_lines.append(('children', ''))
                        has_children_marker = True
                    else:
                        body_lines.append(('expr', expr))
                    has_content = True
                elif part:
                    escaped = esc(part)
                    if escaped.strip():
                        body_lines.append(('html', escaped))
                        has_content = True
            if has_content:
                body_lines.append(('html_nl', ''))
            continue

        # ── HTML ปกติ ────────────────────────────────────────────────────
        escaped = esc(line)
        if escaped.strip():
            body_lines.append(('html', escaped + '\\n'))

    # ── Generate .c file ─────────────────────────────────────────────────
    out = []
    out.append('/* AUTO-GENERATED by tools/cxnc — do not edit */')
    out.append('#include "pages.h"')
    for inc in includes:
        out.append(inc)
    out.append('')

    if scope_lines:
        out.extend(scope_lines)
        out.append('')

    # ── @meta — emit PageMeta struct before the render fn ────────────────
    if meta and not is_layout and not fn_name:
        out.append('static const PageMeta _page_meta = {')
        for key in META_KEYS:
            if key in meta:
                out.append(f'    .{key} = "{meta[key]}",')
        out.append('};')
        out.append('')

    if is_layout:
        if not has_children_marker:
            print(f'[cxnc] warning: {src_path} has no {{{{children}}}} marker — page content will not render',
                  file=sys.stderr)
        out.append('void app_layout(HttpRequest *req, PageCtx *ctx, PageFn child) {')
        out.append('    (void)req;')
    elif fn_name:
        out.append(f'void {fn_name}(PageCtx *ctx) {{')
    else:
        out.append('static void render(HttpRequest *req, PageCtx *ctx) {')
        out.append('    (void)req;')

    # รวม html segments ติดกันเป็น call เดียว เพื่อลด function calls
    # Coalesce consecutive static output (html + html_nl) into one
    # page_write_n call with a concatenated string literal. The length
    # becomes a compile-time sizeof — no runtime strlen, and the small
    # memcpy can be inlined to direct stores by the compiler.
    i = 0
    while i < len(body_lines):
        kind, val = body_lines[i]
        if kind == 'raw':
            out.append(f'    {val}')
            i += 1
        elif kind == 'expr':
            out.append(f'    page_writef(ctx, "%s", {val});')
            i += 1
        elif kind == 'children':
            out.append('    if (child) child(req, ctx);')
            i += 1
        elif kind in ('html', 'html_nl'):
            segments = []
            j = i
            while j < len(body_lines) and body_lines[j][0] in ('html', 'html_nl'):
                if body_lines[j][0] == 'html':
                    segments.append(body_lines[j][1])
                else:  # html_nl
                    segments.append('\\n')
                j += 1
            # emit as C adjacent-string-literal concatenation — compiler joins at compile time
            literal = '" "'.join(segments)
            out.append(f'    page_write_n(ctx, "{literal}", sizeof("{literal}") - 1);')
            i = j
        else:
            i += 1

    out.append('}')
    out.append('')

    if route and not is_layout and not fn_name:
        out.append('__attribute__((constructor))')
        if meta:
            out.append(f'static void _cxn_page_ctor(void) {{ '
                       f'add_page_meta("GET", "{route}", render, &_page_meta); }}')
        else:
            out.append(f'static void _cxn_page_ctor(void) {{ '
                       f'add_page("GET", "{route}", render); }}')
        out.append('')

    with open(dst_path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(out) + '\n')

    if is_layout:
        label = 'layout'
    elif fn_name:
        label = f'fn={fn_name}'
    elif route:
        label = f'route={route}'
    else:
        label = '(no route)'
    print(f'[cxnc] {src_path} → {dst_path}  ({label})')


if __name__ == '__main__':
    if len(sys.argv) != 3:
        print(f'Usage: {sys.argv[0]} input.cxn output_cxn.c', file=sys.stderr)
        sys.exit(1)
    process(sys.argv[1], sys.argv[2])
