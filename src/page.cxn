@meta title       "cnext — Next.js-style SSR in C"
@meta description "A Next.js-inspired SSR framework in C on io_uring + HTTP/2 + LMDB."
<div class="docs-layout">

  <aside class="docs-sidebar">
    <div class="docs-nav-group">Getting Started</div>
    <a href="#intro"      class="docs-nav-link">Introduction</a>
    <a href="#quickstart" class="docs-nav-link">Quick Start</a>
    <div class="docs-nav-group">Routing</div>
    <a href="#routing"    class="docs-nav-link">File Routing</a>
    <a href="#layout"     class="docs-nav-link">Layout</a>
    <div class="docs-nav-group">Pages</div>
    <a href="#templates"  class="docs-nav-link">.cxn Templates</a>
    <a href="#actions"    class="docs-nav-link">Server Actions</a>
    <a href="#apiroutes"  class="docs-nav-link">API Routes</a>
