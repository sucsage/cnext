# ── Build artifacts ──────────────────────────────────────────────────
# compiled binary
server
# object files
*.o
# root-level lib archive (source-mode build) — lib/libcnext.a IS committed
/libcnext.a
# cxnc output (like .next/ in Next.js)
.cnext/

# ── Maintainer-only — not shipped to app developers ──────────────────
lib_dev/
Makefile.maintainer

# ── TLS certs — loaded at runtime from certs/, never committed ───────
certs/

# ── Runtime data — regenerated on each deploy ────────────────────────
data/

# ── Secrets — never commit ───────────────────────────────────────────
*.pem
*.key
*.p12

# ── Editor / OS / tooling ────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
.devcontainer/
.claude/
